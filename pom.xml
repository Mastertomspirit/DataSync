	<groupId>de.spiritscorp</groupId>
	<artifactId>datasync</artifactId>
	<version>1.1.0.0-alpha</version>
	<name>Data Sync</name>
	<description>
	    DataSync is a high-performance, multi-threaded file synchronization and data management solution designed for robust asset alignment and backup automation. 
	    Engineered with concurrency in mind, it features intelligent background job scheduling, advanced duplicate detection mechanisms, and high-efficiency scanning. 
	    With integrated structured JSON logging, DataSync provides enterprise-grade observability and seamless integration into automated server monitoring stacks.
	</description>
	<inceptionYear>2022</inceptionYear>
	<url>https://github.com/Mastertomspirit/DataSync</url>
	<developers>
		<developer>
			<id>${app.developer.id}</id>
			<name>${app.owner}</name>
			<email>${app.developer.email}</email>
			<url>${app.developer.url}</url>
			<roles>
				<role>${app.developer.role.lead}</role>
				<role>${app.developer.role.arch}</role>
			</roles>
		</developer>
		<developer>
			<id>Gemini</id>
			<name>Gemini Free</name>
			<roles>
				<role>${app.developer.role.ui}</role>
			</roles>
		</developer>
	</developers>
	<issueManagement>
		<system>GitHub Issues</system>
		<url>https://github.com/Mastertomspirit/DataSync/issues</url>
	</issueManagement>
	<scm>
		<connection>scm:git:git://github.com/Mastertomspirit/DataSync.git</connection>
		<developerConnection>scm:git:ssh://github.com/Mastertomspirit/DataSync.git</developerConnection>
		<url>https://github.com/Mastertomspirit/DataSync/tree/main</url>

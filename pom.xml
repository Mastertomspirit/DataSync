		<stable_version_for_jpackage>1.1.0.0</stable_version_for_jpackage>
		<jpackage.icon>${project.basedir}/src/main/resources/icons/64x64.ico</jpackage.icon>

		<project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
		<javaVersion>25</javaVersion>
		<maven.build.timestamp.format>dd.MM.yyy - HH:mm</maven.build.timestamp.format>
		<maven.compiler.source>${javaVersion}</maven.compiler.source>
		<maven.compiler.target>${javaVersion}</maven.compiler.target>
		<maven.compiler.release>${javaVersion}</maven.compiler.release>

		<app.owner>The Spirit</app.owner>
		<app.developer.id>mastertomspirit</app.developer.id>
		<app.developer.email>thespirit@spiritscorp.network</app.developer.email>
		<app.developer.url>https://github.com/mastertomspirit</app.developer.url>

		<app.description.short>Hochperformante Anwendung zur Dateisynchronisation und Duplikaterkennung mit automatisiertem Job-Scheduling.</app.description.short>
		<app.developer.role.lead>Lead Developer</app.developer.role.lead>
		<app.developer.role.arch>Software Architect</app.developer.role.arch>
		<app.developer.role.ui>UI Engineer</app.developer.role.ui>

		<gpg.key>${app.developer.email}</gpg.key>
		<gpg.keyid>4946A1BD46D461AD</gpg.keyid>

							<type>IMAGE</type>
							<runtimeimage>target/maven-jlink/default</runtimeimage>
							<appversion>${stable_version_for_jpackage}</appversion>
							<copyright>GPL 3.0</copyright>
							<description>${app.description.short}</description>
							<vendor>${app.owner}</vendor>
							<icon>${jpackage.icon}</icon>
							<module>de.spiritscorp.datasync/de.spiritscorp.datasync.Main</module>
							<javaoptions>-Dfile.encoding=UTF-8 -Xms32m -Xmx4096m</javaoptions>
							<javaoptions> -Dapp.instance.name=${project.artifactId}_v${project.version}</javaoptions>
							<javaoptions>--enable-native-access=javafx.graphics</javaoptions>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<!-- Copies project resource files (e.g., the generated `info.xml`) into the designated build target or package structure. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-resources-plugin</artifactId>
				<version>${pl_resources.version}</version>
				<executions>
					<execution>
						<id>copy-runtime-to-jar</id>
						<phase>package</phase>
						<goals>
							<goal>copy-resources</goal>
						</goals>
						<configuration>
							<outputDirectory>target/${project.artifactId}/jar/${project.artifactId}</outputDirectory>
							<resources>
								<resource>
									<directory>target/maven-jlink/default</directory>
									<includes>
										<include>**/*</include>
									</includes>
								</resource>
							</resources>
						</configuration>
					</execution>
					<execution>
						<id>copy-info-jar</id>
						<phase>package</phase>
						<goals>
							<goal>copy-resources</goal>
						</goals>
						<configuration>
							<outputDirectory>target/${project.artifactId}/jar/${project.artifactId}</outputDirectory>
							<resources>
								<resource>
									<directory>target/classes</directory>
									<includes>
										<include>info.xml</include>
									</includes>
								</resource>
							</resources>
						</configuration>
					</execution>
					<execution>
						<id>copy-fat-jar</id>
						<phase>package</phase>
						<goals>
							<goal>copy-resources</goal>
						</goals>
						<configuration>
							<outputDirectory>target/${project.artifactId}/jar</outputDirectory>
							<resources>
								<resource>
									<directory>target</directory>
									<includes>
										<include>${project.artifactId}-full.jar</include>
									</includes>
								</resource>
							</resources>
						</configuration>
					</execution>
					<execution>
						<id>copy-jar-to-runtime</id>
						<phase>package</phase>
						<goals>
							<goal>copy-resources</goal>
						</goals>
						<configuration>
							<outputDirectory>target/${project.artifactId}/jar/${project.artifactId}</outputDirectory>
							<resources>
								<resource>
									<directory>target</directory>
									<includes>
										<include>${project.artifactId}.jar</include>
									</includes>
								</resource>
							</resources>
						</configuration>
					</execution>
					<execution>
						<id>copy-info-image</id>
						<phase>package</phase>
						<goals>
							<goal>copy-resources</goal>
						</goals>
						<configuration>
							<outputDirectory>target/${project.artifactId}/image/${project.artifactId}</outputDirectory>
							<resources>
								<resource>
									<directory>target/classes</directory>
									<includes>
										<include>info.xml</include>
									</includes>
								</resource>
							</resources>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<!-- Copies project resource files (e.g., the generated `info.xml`) into the designated build target or package structure. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-assembly-plugin</artifactId>
				<version>${pl_assembly.version}</version>
				<executions>
					<execution>
						<id>create-jar-zip</id>
						<phase>package</phase>
						<goals>
							<goal>single</goal>
						</goals>
						<configuration>
							<finalName>${project.artifactId}-jar</finalName>
							<appendAssemblyId>false</appendAssemblyId>
							<outputDirectory>${project.build.directory}/${project.artifactId}/jar</outputDirectory>
							<descriptors>
								<descriptor>buildConfig/assembly/zip-full-jar.xml</descriptor>
							</descriptors>
						</configuration>
					</execution>
					<execution>
						<id>create-image-zip</id>
						<phase>package</phase>
						<goals>
							<goal>single</goal>
						</goals>
						<configuration>
							<finalName>${project.artifactId}-image</finalName>
							<appendAssemblyId>false</appendAssemblyId>
							<outputDirectory>${project.build.directory}/${project.artifactId}/image</outputDirectory>
							<descriptors>
								<descriptor>buildConfig/assembly/zip-jpackage.xml</descriptor>
							</descriptors>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<!-- Performs static analysis on bytecode to detect performance issues, potential bugs, and security vulnerabilities. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-pmd-plugin</artifactId>
				<version>${pl_pmd.version}</version>
				<configuration>
					<failOnViolation>true</failOnViolation>
					<printFailingErrors>true</printFailingErrors>
					<analysisCache>true</analysisCache>
					<excludes>
						<exclude>**/generated/**</exclude>
					</excludes>
					<analysisCacheLocation>${project.basedir}/.cache/pmd.cache</analysisCacheLocation>
					<rulesets>
						<ruleset>${project.basedir}/buildConfig/pmd-ruleset.xml</ruleset>
					</rulesets>
				</configuration>
				<executions>
					<execution>
						<phase>verify</phase>
						<goals>
							<goal>pmd</goal>
							<goal>cpd</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<!-- Automates release management, including VCS tagging, updating POM versions, and deploying artifacts. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-release-plugin</artifactId>
				<version>${pl_release}</version>
				<configuration>
					<goals>clean compile jlink:jlink verify</goals>
					<tagNameFormat>v@{project.version}</tagNameFormat>
					<autoVersionSubmodules>true</autoVersionSubmodules>
				</configuration>
			</plugin>
			<!-- Packages the project's source code into a separate JAR archive for debugging and reference purposes. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-source-plugin</artifactId>
				<version>${pl_source}</version>
				<executions>
					<execution>
						<id>attach-sources</id>
						<phase>verify</phase>
						<goals>
							<goal>jar-no-fork</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<!-- Generates comprehensive HTML API documentation from the structured Javadoc comments in the source code. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-javadoc-plugin</artifactId>
				<version>${pl_javadoc}</version>
				<configuration>
					<!--					<legacyMode>true</legacyMode>  -->
					<doclint>none</doclint>
				</configuration>
				<executions>
					<execution>
						<id>attach-javadocs</id>
						<phase>verify</phase>
						<goals>
							<goal>jar</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<!-- Digitally signs built artifacts using GnuPG to guarantee authenticity and integrity during distribution. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-gpg-plugin</artifactId>
				<version>${pl_gpg}</version>
				<executions>
					<execution>
						<id>sign-artifacts</id>
						<phase>verify</phase>
						<goals>
							<goal>sign</goal>
						</goals>
						<configuration>
							<gpgArguments>
								<arg>--batch</arg>
								<arg>--pinentry-mode</arg>
								<arg>loopback</arg>
							</gpgArguments>
							<keyname>${gpg.key}</keyname>
							<passphraseEnvName>GPG_PASSPHRASE</passphraseEnvName>
							<skip>${gpg.skip}</skip>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-jxr-plugin</artifactId>
				<version>${pl_jxr.version}</version>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-site-plugin</artifactId>
				<version>${pl_site.version}</version>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-report-plugin</artifactId>
				<version>${pl_surefire.version}</version>
			</plugin>
		</plugins>
	</build>

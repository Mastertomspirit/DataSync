	<build>
		<finalName>${project.artifactId}</finalName>
		<directory>target</directory>
		<outputDirectory>target/classes</outputDirectory>
		<testOutputDirectory>target/test-classes</testOutputDirectory>
		<sourceDirectory>src/main/java</sourceDirectory>
		<testSourceDirectory>src/test/java</testSourceDirectory>
		<resources>
			<resource>
				<directory>src/main/resources</directory>
			</resource>
		</resources>
		<testResources>
			<testResource>
				<directory>src/test/resources</directory>
			</testResource>
		</testResources>
		<plugins>
			<!-- Cleans up whitespaces, organizes imports, and formats source code according to style guides. -->
			<plugin>
				<groupId>net.revelc.code.formatter</groupId>
				<artifactId>formatter-maven-plugin</artifactId>
				<version>${pl_formatter}</version>
				<configuration>
					<configFile>buildConfig/formatter.xml</configFile>
					<encoding>UTF-8</encoding>
					<compilerSource>${javaVersion}</compilerSource>
					<compilerCompliance>${javaVersion}</compilerCompliance>
					<removeTrailingWhitespace>true</removeTrailingWhitespace>
					<includes>
						<include>**/*.java</include>
						<include>**/*.properties</include>
					</includes>
					<excludes>
						<exclude>**/target/**</exclude>
					</excludes>
				</configuration>
				<executions>
					<execution>
						<phase>validate</phase>
						<goals>
							<goal>format</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<!-- Inspects Java source code to enforce strict adherence to defined coding standards and conventions. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-checkstyle-plugin</artifactId>
				<version>${pl_checkstyle.version}</version>
				<dependencies>
					<dependency>
						<groupId>com.puppycrawl.tools</groupId>
						<artifactId>checkstyle</artifactId>
						<version>${pl_checkstyle_puppycrawl.version}</version>
					</dependency>
				</dependencies>
				<configuration>
					<configLocation>buildConfig/checkstyle.xml</configLocation>
					<consoleOutput>true</consoleOutput>
					<failsOnError>true</failsOnError>
					<linkXRef>true</linkXRef>
					<cacheFile>${project.basedir}/.cache/checkstyle.cache</cacheFile>
					<propertyExpansion>checkstyle.enableExternalDtdLoad=true</propertyExpansion>
				</configuration>
				<executions>
					<execution>
						<phase>validate</phase>
						<goals>
							<goal>checkstyle</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<!-- Manages, formats, and validates license headers across source code files. -->
			<plugin>
				<groupId>com.mycila</groupId>
				<artifactId>license-maven-plugin</artifactId>
				<version>${pl_license}</version>
				<configuration>
					<skip>false</skip>
					<properties>
						<owner>${app.owner}</owner>
						<email>${app.developer.email}</email>
					</properties>
					<licenseSets>
						<licenseSet>
							<header>buildConfig/license-header.txt</header>
							<includes>
								<include>src/main/java/**</include>
								<include>src/test/java/**</include>
							</includes>
							<excludes>
								<exclude>**/Main.java</exclude>
								<exclude>**/package-info.java</exclude>
								<exclude>**/module-info.java</exclude>
								<exclude>src/main/resources/**</exclude>
								<exclude>src/test/resources/**</exclude>
							</excludes>
						</licenseSet>
					</licenseSets>
					<mapping>
						<java>JAVAPKG_STYLE</java>
					</mapping>
				</configuration>
				<executions>
					<execution>
						<id>update-license</id>
						<phase>validate</phase>
						<goals>
							<goal>format</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<!-- Integrates Git metadata (such as commit hash and branch) into the application artifacts. -->
			<plugin>
				<groupId>io.github.git-commit-id</groupId>
				<artifactId>git-commit-id-maven-plugin</artifactId>
				<version>${pl_git_commit_id}</version>
				<executions>
					<execution>
						<id>get-the-git-infos</id>
						<goals>
							<goal>revision</goal>
						</goals>
						<phase>initialize</phase>
					</execution>
				</executions>
				<configuration>
					<generateGitPropertiesFile>false</generateGitPropertiesFile>
					<injectAllReactorProjects>true</injectAllReactorProjects>
				</configuration>
			</plugin>
			<!-- Provides goals to read and write properties from files or URLs, and set system properties. -->
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>properties-maven-plugin</artifactId>
				<version>${pl_properties.version}</version>
			</plugin>
			<!-- Provides the ability to run Ant tasks (e.g., copying files or creating directories) within Maven. -->
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-antrun-plugin</artifactId>
				<version>${pl_antrun.version}</version>
				<executions>
					<execution>
						<id>generate-info-xml</id>
						<phase>prepare-package</phase>
						<goals>
							<goal>run</goal>
						</goals>
						<configuration>
							<target>
								<condition property="gpg.is.signed" value="false" else="true">
									<or>
										<equals arg1="${gpg.skip}" arg2="true" />
										<and>
											<contains string="${sun.java.command}" substring="package" />
											<not>
												<contains string="${sun.java.command}" substring="verify" />
											</not>
											<not>
												<contains string="${sun.java.command}" substring="install" />
											</not>
											<not>
												<contains string="${sun.java.command}" substring="deploy" />
											</not>
										</and>
									</or>
								</condition>
								<echo file="target/classes/info.xml">
<![CDATA[<?xml version="1.0" encoding="UTF-8"?>
<app>
	<name>${project.name}</name>
	<groupId>${project.groupId}</groupId>
	<artifactId>${project.artifactId}</artifactId>
	<description>${project.description}</description>
	<url>${project.url}</url>
	<inceptionYear>${project.inceptionYear}</inceptionYear>
	<version>${project.version}</version>
	<javaVersion>${javaVersion}</javaVersion>
	<license>GNU GPL 3</license>
	<developers>
	    <developer>
	        <name>${app.owner}</name>
	        <email>${app.developer.email}</email>
	        <url>${app.developer.url}</url>
	        <roles>
				<role>${app.developer.role.lead}</role>
			    <role>${app.developer.role.arch}</role>
	        </roles>
	    </developer>
	</developers>
	<buildEnvironment>
	    <mavenVersion>${maven.version}</mavenVersion>
	    <javaVendor>${java.vendor}</javaVendor>
	    <javaRuntimeVersion>${java.runtime.version}</javaRuntimeVersion>
		<buildTimestampUtc>${maven.build.timestamp}</buildTimestampUtc>
